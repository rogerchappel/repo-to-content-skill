{
  "name": "repo-to-content-skill",
  "version": "0.1.0",
  "description": "Generate evidence-backed launch content briefs from local repositories.",
  "type": "module",
  "bin": {
    "repo-to-content": "./bin/repo-to-content.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/repo-to-content.js",
    "smoke": "node bin/repo-to-content.js fixtures/sample-repo --format markdown",
    "smoke:json": "node bin/repo-to-content.js fixtures/sample-repo --format json",
    "build": "npm run check && npm test",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run smoke:json && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "content",
    "oss",
    "launch",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repo-to-content-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repo-to-content-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/repo-to-content-skill#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "fixtures",
    "docs",
    "scripts",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ]
}
